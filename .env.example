# ─── Copy to .env and fill in ALL values ────────────────────────────────────
NODE_ENV=development
PORT=3001

# MySQL — never commit real credentials
DATABASE_URL="mysql://sku_user:CHANGE_ME@localhost:3306/sku_engine"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — generate with: openssl rand -hex 64
JWT_SECRET="CHANGE_ME_openssl_rand_-hex_64"
JWT_REFRESH_SECRET="CHANGE_ME_openssl_rand_-hex_64_DIFFERENT"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Security
BCRYPT_ROUNDS=12
THROTTLE_TTL=60
THROTTLE_LIMIT=100
CORS_ORIGINS="http://localhost:3000"

# Seed admin (prisma/seed.ts only — not used at runtime)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
SEED_ADMIN_NAME="Administrator"
