generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Users ──────────────────────────────────────────────────────────────────

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  passwordHash String
  name         String
  role         Role          @default(STAFF)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  skus         Sku[]
  auditLogs    AuditLog[]
  templates    SkuTemplate[]
  @@index([email])
}

enum Role { ADMIN STAFF }

// ── Masters ────────────────────────────────────────────────────────────────

model Master {
  id          Int        @id @default(autoincrement())
  name        String
  code        String     @unique
  description String?    @db.Text
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  categories  Category[]
  @@index([code])
  @@index([sortOrder])
}

// ── Categories (N-level via materialized path) ─────────────────────────────

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  code        String
  description String?    @db.Text
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  depth       Int        @default(0)
  path        String     @db.VarChar(500)
  masterId    Int
  parentId    Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  master      Master     @relation(fields: [masterId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  skus        Sku[]
  @@unique([code, parentId])
  @@index([masterId])
  @@index([parentId])
  @@index([path])
  @@index([isActive])
}

// ── Variants ───────────────────────────────────────────────────────────────

model VariantType {
  id          Int            @id @default(autoincrement())
  name        String         @unique
  description String?
  sortOrder   Int            @default(0)
  isRequired  Boolean        @default(false)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  values      VariantValue[]
  skuVariants SkuVariant[]
  @@index([sortOrder])
}

model VariantValue {
  id            Int          @id @default(autoincrement())
  name          String
  code          String
  description   String?
  sortOrder     Int          @default(0)
  isActive      Boolean      @default(true)
  variantTypeId Int
  createdAt     DateTime     @default(now())
  variantType   VariantType  @relation(fields: [variantTypeId], references: [id], onDelete: Cascade)
  skuVariants   SkuVariant[]
  @@unique([code, variantTypeId])
  @@index([variantTypeId])
}

// ── SKUs ───────────────────────────────────────────────────────────────────

model Sku {
  id          Int          @id @default(autoincrement())
  sku         String       @unique
  productName String
  description String?      @db.Text
  notes       String?      @db.Text
  categoryId  Int
  createdById Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  category    Category     @relation(fields: [categoryId], references: [id])
  createdBy   User         @relation(fields: [createdById], references: [id])
  variants    SkuVariant[]
  @@index([categoryId])
  @@index([createdById])
  @@index([isActive])
  @@index([sku])
}

model SkuVariant {
  id             Int          @id @default(autoincrement())
  skuId          Int
  variantTypeId  Int
  variantValueId Int
  sku            Sku          @relation(fields: [skuId], references: [id], onDelete: Cascade)
  variantType    VariantType  @relation(fields: [variantTypeId], references: [id])
  variantValue   VariantValue @relation(fields: [variantValueId], references: [id])
  @@unique([skuId, variantTypeId])
  @@index([variantTypeId])
  @@index([variantValueId])
}

// ── Import ─────────────────────────────────────────────────────────────────

model ImportJob {
  id          Int          @id @default(autoincrement())
  status      ImportStatus @default(PENDING)
  totalRows   Int          @default(0)
  mappedRows  Int          @default(0)
  failedRows  Int          @default(0)
  savedRows   Int          @default(0)
  inputData   Json
  results     Json?
  createdAt   DateTime     @default(now())
  completedAt DateTime?
}

enum ImportStatus { PENDING PROCESSING COMPLETED FAILED }

model ImportKeyword {
  id         Int    @id @default(autoincrement())
  keyword    String @unique
  entityType String // 'category' | 'variant_value'
  entityId   Int
  priority   Int    @default(0)
  @@index([entityType, entityId])
  @@index([priority])
}

// ── SKU Templates ──────────────────────────────────────────────────────────

model SkuTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  categoryId  Int?
  variantData Json?
  createdById Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id])
}

// ── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  before     Json?
  after      Json?
  userId     Int?
  ipAddress  String?
  userAgent  String?  @db.Text
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
}
